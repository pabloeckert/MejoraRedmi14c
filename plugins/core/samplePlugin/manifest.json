{
  "id": "sample-plugin",
  "name": "Sample Plugin",
  "version": "1.0.0",
  "description": "Plugin de ejemplo que muestra cómo crear plugins para Phone Optimizer",
  "author": "Phone Optimizer Team",
  "type": "core",
  "main": "index.js",
  "ui": "ui.jsx",
  "permissions": ["adb.shell", "logs.read", "ml.predict"],
  "enabled": true,
  "hooks": ["afterOptimization", "onDeviceConnect", "onDeviceDisconnect"],
  "settings": {
    "greeting": "Hola desde Sample Plugin",
    "logLevel": "info"
  }
}
