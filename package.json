{
  "name": "phone-optimizer",
  "version": "1.0.0",
  "description": "Optimizador Inteligente para teléfonos Android - Pablo & Sindy",
  "main": "main.js",
  "author": "Pablo Eckert <pabloeckert@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "build": "vite build && electron-builder --win --linux --mac",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "build:mac": "vite build && electron-builder --mac",
    "start": "electron .",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\""
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0"
  }
}
